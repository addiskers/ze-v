GEMINI_API_KEY=
# Must be a valid Gemini Live model id for your account + installed SDK. A warm,
# low-latency half-cascade/flash-live model is recommended for this RSVP bot.
MODEL=gemini-3.1-flash-live-preview

# ---- Personalisation ----
# Optional phone->first-name directory so the agent greets members by name
# ("Hello Pratik!"). CSV columns: phone,first_name  (or a JSON map). This file is
# PII — keep it out of version control. A per-call "name" (via /call-me) overrides it.
MEMBER_DIRECTORY_PATH=data/members.csv

# ---- Plivo (phone calls) ----
# From your Plivo console. PLIVO_FROM_NUMBER must be a Plivo number you own (E.164).
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_FROM_NUMBER=
# Public https URL Plivo can reach for the /plivo/answer webhook (e.g. an ngrok tunnel).
PUBLIC_URL=

# ---- Call behaviour ----
# Safety cap: hang up any call that runs longer than this many seconds (the agent
# normally ends the call itself via the end_call tool right after its goodbye).
CALL_MAX_SECONDS=420
# Gentle pause (seconds) AFTER the goodbye audio has fully drained, before hanging up,
# so the call never cuts off mid-word. Raise it if endings feel abrupt.
CALL_HANGUP_GRACE_SECONDS=1.0
# After the agent says goodbye (end_call), how long to keep listening in case the
# member wants to continue. If they speak, the hangup is cancelled and the call goes
# on. Together with CALL_HANGUP_GRACE_SECONDS this sets the post-goodbye dead air
# (~3s total at these defaults). Raise it to give members more time to jump back in.
CALL_END_GRACE_SECONDS=2
# Never cut the caller off mid-sentence: inbound audio is watched in real time (a VAD
# energy gate) so activity registers before transcription catches up.
EO_VAD_RMS_THRESHOLD=500              # inbound voice gate; silence ~0, comfort-noise ~6, speech >~1000
EO_HANGUP_ABORT_WINDOW_SECONDS=1.2   # abort a pending hangup if the caller voiced this recently
EO_HOLD_GRACE_SECONDS=30             # keep the line open this long after "hold on / give me a minute"
EO_POST_RSVP_IDLE_SECONDS=12         # quiet window after the RSVP before auto-hangup
# Call recording: mix caller+agent into one mono 8kHz WAV per call (DATA_DIR/recordings/<call_sid>.wav),
# played back from the admin call drawer. ~16 KB/s (~3 MB per 3-min call). Set false to disable.
EO_RECORD_CALLS=true
EO_RECORD_MAX_SECONDS=420            # cap a single recording's length (matches CALL_MAX_SECONDS)
# ---- Reply latency (Gemini server VAD — tune on prod, watch the "TURN LATENCY" log lines) ----
# How much caller silence ends their turn. THE biggest lever on reply delay: lower =
# snappier replies but more risk of cutting slow speakers. 400-550 is the sane range.
EO_VAD_SILENCE_MS=550
EO_VAD_PREFIX_MS=250                 # committed speech required before a turn opens (anti click/echo)
EO_VAD_START_SENSITIVITY=LOW         # LOW = anti-echo on phone lines; HIGH = catches softer starts
EO_VAD_END_SENSITIVITY=HIGH          # HIGH = snappy end-of-turn; LOW = more patient
EO_FAREWELL_WAIT_SECONDS=4           # head start for a still-generating goodbye before hangup drain
EO_AUDIO_INPUT_QUEUE_FRAMES=150      # inbound audio buffer to Gemini (drop-oldest past this, stays live)
# ---- Silence check ("are you still there?") ----
EO_SILENCE_CHECK=true
EO_SILENCE_PROMPT_SECONDS=6          # mutual silence before the agent asks "are you still there?"
EO_SILENCE_HANGUP_SECONDS=10         # further caller silence before a goodbye + hangup
# ---- Noise squelch (background voices/noise) ----
# Replaces below-gate inbound audio with clean silence before Gemini hears it (never
# drops frames — the server VAD needs to hear the quiet). Reduces the agent replying to
# surrounding voices. START DISABLED; enable after a live-call check of barge-in and a
# soft-spoken caller. RMS gate: speech is typically >1000, room noise far lower.
EO_NOISE_GATE=false
EO_NOISE_GATE_RMS=250                # squelch gate (RMS) — keep LOWER than EO_VAD_RMS_THRESHOLD
EO_NOISE_GATE_HANGOVER_S=0.6         # keep passing audio this long after the last voiced frame
# ---- Calling hours (night hard-stop) ----
# Default window for callbacks with no campaign; per-campaign windows are set at creation.
# "HH:MM" in IST. No automated campaign/callback dials happen outside the window (manual
# "Call now" is always allowed).
EO_CALL_WINDOW_START=09:00
EO_CALL_WINDOW_END=21:00

# ---- Super-Admin dashboard (/superadmin) ----
# Shared key required to open /superadmin and call /api/admin/* (X-Admin-Key / ?key=)
ANALYTICS_SECRET=eo2026

# ---- EO Admin platform (the React /admin app) ----
# First admin user, seeded ONLY if the users table is empty. Change these in prod,
# then change the password again from the Profile page after first login.
EO_ADMIN_USER=eoadmin
EO_ADMIN_PASS=change-me-now
# Signing key for EO login tokens (any long random string). Falls back to ANALYTICS_SECRET.
EO_SESSION_SECRET=
# Global cap on simultaneous LIVE calls — campaign dials + callbacks SHARE this.
# When full, new campaign dials and due callbacks wait (queued) and fire when a
# slot frees; callbacks get first claim. Read at dial time, so .env works here.
MAX_LIVE_CALLS=2
# Campaign dialer pacing (optional; defaults shown)
# EO_CAMPAIGN_MAX_CONCURRENT=5     # max simultaneous campaign calls
# EO_CAMPAIGN_MAX_PER_TICK=3       # new dials started per 30s tick
# EO_CAMPAIGN_NOANSWER_SECONDS=90  # ring window before a dial counts as no-answer

# ---- Call log + cost storage ----
# JSON call records are written to DATA_DIR/calls/<id>.json.
DATA_DIR=

# ---- Gemini cost rates (USD per 1,000,000 tokens, paid tier) ----
RATE_GEMINI_TEXT_IN=0.75
RATE_GEMINI_AUDIO_IN=3.00
RATE_GEMINI_IMGVID_IN=1.00
RATE_GEMINI_TEXT_OUT=4.50
RATE_GEMINI_AUDIO_OUT=12.00

# ---- Telephony fallback rate (USD per minute) ----
RATE_TWILIO_PER_MIN=0.014

# ---- Auto-callback scheduler (re-dials members who asked to be called back) ----
# Set ENABLED=false to capture/queue callbacks without dialing (e.g. while Plivo
# outbound is still KYC-blocked). All others are optional; defaults shown.
CALLBACK_SCHEDULER_ENABLED=true
CALLBACK_POLL_INTERVAL=30          # seconds between scheduler ticks
CALLBACK_DEFAULT_OFFSET=7200       # default callback delay (s) when no time given (2h)
CALLBACK_MIN_DELAY=60              # floor — never schedule in the past
CALLBACK_MAX_HORIZON=604800        # ceiling on how far out (7 days)
CALLBACK_MAX_ATTEMPTS=3            # dial attempts before marking failed
CALLBACK_BACKOFF_BASE=300          # retry backoff base (s), doubles per attempt
CALLBACK_BACKOFF_MAX=3600          # retry backoff cap (s)
CALLBACK_MAX_PER_TICK=5            # max dials initiated per tick
CALLBACK_DIAL_TIMEOUT=60           # max seconds to wait on a single dial before failing it
CALLBACK_FAILFAST_THRESHOLD=5      # consecutive failures that trip the breaker
CALLBACK_FAILFAST_COOLDOWN=1800    # breaker pause (s) — survives restarts
CALLBACK_MAX_GENERATIONS=1         # cap on callback->callback chains
CALLBACK_TZ=Asia/Kolkata           # timezone for parsing spoken/default times
