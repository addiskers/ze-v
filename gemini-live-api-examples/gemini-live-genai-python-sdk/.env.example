GEMINI_API_KEY=
# Must be a valid Gemini Live model id for your account + installed SDK. A warm,
# low-latency half-cascade/flash-live model is recommended for this RSVP bot.
MODEL=gemini-3.1-flash-live-preview

# ---- Personalisation ----
# Optional phone->first-name directory so the agent greets members by name
# ("Hello Pratik!"). CSV columns: phone,first_name  (or a JSON map). This file is
# PII — keep it out of version control. A per-call "name" (via /call-me) overrides it.
MEMBER_DIRECTORY_PATH=data/members.csv

# ---- Plivo (phone calls) ----
# From your Plivo console. PLIVO_FROM_NUMBER must be a Plivo number you own (E.164).
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_FROM_NUMBER=
# Public https URL Plivo can reach for the /plivo/answer webhook (e.g. an ngrok tunnel).
PUBLIC_URL=

# ---- Call behaviour ----
# Safety cap: hang up any call that runs longer than this many seconds (the agent
# normally ends the call itself via the end_call tool right after its goodbye).
CALL_MAX_SECONDS=420
# Gentle pause (seconds) after the goodbye finishes before hanging up, so the call
# never cuts off mid-word. Raise it if endings feel abrupt.
CALL_HANGUP_GRACE_SECONDS=2.5
# After the agent says goodbye (end_call), how long to keep listening in case the
# member wants to continue. If they speak, the hangup is cancelled and the call goes
# on. Raise it to give members more time to jump back in.
CALL_END_GRACE_SECONDS=4

# ---- Super-Admin dashboard (/superadmin) ----
# Shared key required to open /superadmin and call /api/admin/* (X-Admin-Key / ?key=)
ANALYTICS_SECRET=eo2026

# ---- EO Admin platform (the React /admin app) ----
# First admin user, seeded ONLY if the users table is empty. Change these in prod,
# then change the password again from the Profile page after first login.
EO_ADMIN_USER=eoadmin
EO_ADMIN_PASS=change-me-now
# Signing key for EO login tokens (any long random string). Falls back to ANALYTICS_SECRET.
EO_SESSION_SECRET=
# Campaign dialer pacing (optional; defaults shown)
# EO_CAMPAIGN_MAX_CONCURRENT=5     # max simultaneous campaign calls
# EO_CAMPAIGN_MAX_PER_TICK=3       # new dials started per 30s tick
# EO_CAMPAIGN_NOANSWER_SECONDS=90  # ring window before a dial counts as no-answer

# ---- Call log + cost storage ----
# JSON call records are written to DATA_DIR/calls/<id>.json.
DATA_DIR=

# ---- Gemini cost rates (USD per 1,000,000 tokens, paid tier) ----
RATE_GEMINI_TEXT_IN=0.75
RATE_GEMINI_AUDIO_IN=3.00
RATE_GEMINI_IMGVID_IN=1.00
RATE_GEMINI_TEXT_OUT=4.50
RATE_GEMINI_AUDIO_OUT=12.00

# ---- Telephony fallback rate (USD per minute) ----
RATE_TWILIO_PER_MIN=0.014

# ---- Auto-callback scheduler (re-dials members who asked to be called back) ----
# Set ENABLED=false to capture/queue callbacks without dialing (e.g. while Plivo
# outbound is still KYC-blocked). All others are optional; defaults shown.
CALLBACK_SCHEDULER_ENABLED=true
CALLBACK_POLL_INTERVAL=30          # seconds between scheduler ticks
CALLBACK_DEFAULT_OFFSET=7200       # default callback delay (s) when no time given (2h)
CALLBACK_MIN_DELAY=60              # floor — never schedule in the past
CALLBACK_MAX_HORIZON=604800        # ceiling on how far out (7 days)
CALLBACK_MAX_ATTEMPTS=3            # dial attempts before marking failed
CALLBACK_BACKOFF_BASE=300          # retry backoff base (s), doubles per attempt
CALLBACK_BACKOFF_MAX=3600          # retry backoff cap (s)
CALLBACK_MAX_PER_TICK=5            # max dials initiated per tick
CALLBACK_DIAL_TIMEOUT=60           # max seconds to wait on a single dial before failing it
CALLBACK_FAILFAST_THRESHOLD=5      # consecutive failures that trip the breaker
CALLBACK_FAILFAST_COOLDOWN=1800    # breaker pause (s) — survives restarts
CALLBACK_MAX_GENERATIONS=1         # cap on callback->callback chains
CALLBACK_TZ=Asia/Kolkata           # timezone for parsing spoken/default times
