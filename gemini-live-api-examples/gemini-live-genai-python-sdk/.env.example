GEMINI_API_KEY=
MODEL=gemini-3.1-flash-live-preview

# ---- Twilio (phone calls) ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+19785715824
PUBLIC_URL=

# ---- Admin dashboard ----
# Key required to open /admin and call /api/admin/* (X-Admin-Key header / ?key=)
ANALYTICS_SECRET=kataria2026

# ---- Call log + cost storage ----
# JSON call records are written to DATA_DIR/calls/<id>.json.
# NOTE: Render wipes the local filesystem on every deploy. For durable history,
# attach a Render Persistent Disk and set DATA_DIR to a path on it, e.g. /var/data
DATA_DIR=

# ---- Gemini cost rates (USD per 1,000,000 tokens, paid tier) ----
RATE_GEMINI_TEXT_IN=0.75
RATE_GEMINI_AUDIO_IN=3.00
RATE_GEMINI_IMGVID_IN=1.00
RATE_GEMINI_TEXT_OUT=4.50
RATE_GEMINI_AUDIO_OUT=12.00

# ---- Twilio fallback rate (USD per minute) ----
# Only used until Twilio's real billed Call.price is fetched.
RATE_TWILIO_PER_MIN=0.014